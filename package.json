{
  "name": "iicpc",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/api",
    "services/worker",
    "services/frontend"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @iicpc/api",
    "dev:worker": "npm run dev -w @iicpc/worker",
    "dev:frontend": "npm run dev -w @iicpc/frontend",
    "build": "npm run build -ws --if-present",
    "docker:up": "docker-compose up --build",
    "docker:down": "docker-compose down"
  }
}
