:80 {
    # Redirect bare /admin → /admin/ so handle_path below matches
    redir /admin /admin/ 301

    # API — strip /api prefix before proxying
    handle_path /api/* {
        reverse_proxy api:3000
    }

    # Observability root — auth gate (only this page requires credentials)
    @obs-root path /admin/
    handle @obs-root {
        basic_auth {
            {$OBS_USER} {$OBS_PASS_HASH}
        }
        uri strip_prefix /admin
        reverse_proxy observability:3002
    }

    # Observability API sub-routes — no auth needed (port 3002 not published, only reachable via Caddy)
    handle_path /admin/* {
        reverse_proxy observability:3002
    }

    # Frontend — catch-all
    handle {
        reverse_proxy frontend:3001
    }
}
