:80 {
    # Redirect bare /admin → /admin/ so handle below matches
    redir /admin /admin/ 301

    # API — strip /api prefix before proxying
    handle_path /api/* {
        reverse_proxy api:3000
    }

    # Observability UI and API routes — auth gate for all /admin paths
    @obs path /admin /admin/*
    handle @obs {
        basic_auth {
            {$OBS_USER} {$OBS_PASS_HASH}
        }
        uri strip_prefix /admin
        reverse_proxy observability:3002
    }

    # Frontend — catch-all
    handle {
        reverse_proxy frontend:3001
    }
}
